# Database
# Default: SQLite (dev). Swap to PostgreSQL by setting:
#   DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/gym
DATABASE_URL=sqlite:///./gym.db

# JWT
JWT_SECRET=change-me-please-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# CORS - comma separated list of allowed origins
CORS_ORIGINS=http://localhost:5173

# Runtime
ENV=development
